name: Build SketchIDE APK

on:
  push:
    branches: [ "main", "master" ]
  pull_request:
    branches: [ "main", "master" ]
  workflow_dispatch:  # Permet de lancer manuellement le build depuis l'onglet Actions

jobs:
  build:
    name: Build APK
    runs-on: ubuntu-latest

    steps:
      # 1. Récupérer le code source
      - name: Checkout repository
        uses: actions/checkout@v4

      # 2. Installer Flutter avec la version stable
      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.x'  # Utilise la dernière version stable de Flutter 3
          channel: 'stable'
          cache: true  # Met en cache l'installation de Flutter pour accélérer les builds suivants

      # 3. Vérifier l'installation (optionnel)
      - name: Flutter version
        run: flutter --version

      # 4. Récupérer les dépendances
      - name: Install dependencies
        run: flutter pub get

      # 5. Vérifier la validité du projet (optionnel)
      - name: Analyze code
        run: flutter analyze

      # 6. Compiler l'APK en mode release
      - name: Build APK
        run: flutter build apk --release --split-per-abi  # --split-per-abi génère des APK par architecture (armeabi-v7a, arm64-v8a, x86_64)

      # 7. Uploader l'APK en tant qu'artefact
      - name: Upload APK artifacts
        uses: actions/upload-artifact@v4
        with:
          name: sketchide-apk
          path: build/app/outputs/flutter-apk/app-*.apk  # Capture tous les APK générés
          if-no-files-found: error  # Échoue si aucun APK n'est trouvé
